  "keyFeatures": [
    "Intents & Challenges — goal-oriented focus sessions with social accountability and configurable pause thresholds",
    "Gray Engine — context-aware content mediation that modifies webpages based on current focus goal",
    "Ktags — physical NFC tags that gate iOS focus sessions with no software bypass",
    "Friends & Accountability — bilateral friendship model with challenge invitations and participation tracking",
    "Browser Extension — real-time page modification via the Gray Engine based on active intent",
    "iOS companion app — NFC-gated Screen Time blocking via FamilyControls, no VPN required",
    "TypeScript monorepo — Turborepo with Fastify API, Next.js dashboard, MV3 extension, and SwiftUI iOS app",
    "Typed API client — ts-rest contracts shared between server and all client surfaces"
  ],
